# EdgeMarket — dev environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit real secrets.

# Neon PostgreSQL password
DB_PASSWORD=your-neon-password

# JWT signing secret — must be at least 256 bits (32+ bytes), Base64-encoded.
# Generate one with:  openssl rand -base64 32
JWT_SECRET=your-base64-encoded-256-bit-secret

# Java 21 JDK path (Windows path, forward slashes work in Git Bash)
# Uncomment and set if JAVA_HOME is not already in your system environment.
# JAVA_HOME=C:/Program Files/Java/jdk-21.0.x
